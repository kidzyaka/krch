# Конфигурация сервера
SERVER_PORT=443

# Конфигурация SSL/TLS
KEYSTORE_PATH=file:keystore.p12
KEYSTORE_PASSWORD=krchpassword
KEYSTORE_TYPE=PKCS12
KEYSTORE_ALIAS=krch

# Конфигурация базы данных PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/mydatabase
DB_USERNAME=krchuser
DB_PASSWORD=krchpassword
DB_DRIVER=org.postgresql.Driver

# Конфигурация JPA/Hibernate
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
HIBERNATE_FORMAT_SQL=true
DB_PLATFORM=org.hibernate.dialect.PostgreSQLDialect

